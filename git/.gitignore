# Dotfiles Repository .gitignore
# This file contains sensible defaults for common unwanted files

# === Operating System Files ===
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
.directory
*~

# === Editor and IDE Files ===
# Vim
*.swp
*.swo
*.swn
.*.sw?
*~
.netrwhist
*.netrwhist

# VSCode
.vscode/
*.code-workspace

# JetBrains IDEs
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Emacs
\#*\#
.\#*

# === Temporary and Backup Files ===
*.tmp
*.temp
*.bak
*.backup
*.orig
*.log

# === Environment and Secrets ===
.env
.env.*
!.env.example
*.key
*.pem
credentials.json

# === Local Git Configuration ===
.gitconfig.local

# === Dependencies and Build Artifacts ===
node_modules/
vendor/
*.pyc
__pycache__/
.pytest_cache/
.mypy_cache/

# === Pi Coding Agent ===
# Pi stores credentials, runtime binaries, and session history under ~/.pi/agent
# Only settings.json (and authored skills/extensions/prompts/themes) should be tracked.
.pi/agent/auth.json
.pi/agent/sessions/
.pi/agent/bin/
*.pre-stow.bak

# === Database CLI Tools ===
# PostgreSQL - local history and logs contain sensitive queries
.config/pgcli/history
.config/pgcli/log
.config/pgcli/casing
.psql_history

# === macOS Specific ===
# Ignore thumbnails created by macOS
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
